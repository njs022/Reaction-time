#include <msp430.h>

// LCD pin definitions (Port 2)
#define RS  BIT0   // P2.0 -> LCD RS
#define EN  BIT1   // P2.1 -> LCD E
#define D4  BIT2   // P2.2 -> LCD D4
#define D5  BIT3   // P2.3 -> LCD D5
#define D6  BIT4   // P2.4 -> LCD D6
#define D7  BIT5   // P2.5 -> LCD D7

// Experiment constants
#define NUM_TRIALS 10

// Global time base
volatile unsigned long time_ms = 0;
volatile unsigned long last_press = 0;

// Button event flag
volatile unsigned char button_pressed = 0;

// Function prototypes
void lcd_pulse_enable(void);
void lcd_send_nibble(unsigned char nibble);
void lcd_cmd(unsigned char cmd);
void lcd_data(unsigned char data);
void lcd_init(void);
void lcd_clear(void);
void lcd_set_cursor(unsigned char row, unsigned char col);
void lcd_print(char *str);
void lcd_print_time(unsigned int ms);
void delay_ms(unsigned int ms);
void lcd_print_trial(unsigned int trial);
void lcd_print_num(unsigned int num);

// Random delay helper
unsigned int random_delay(void);

// Main
void main(void)
{
    unsigned int trial;
    unsigned int reaction_time;
    unsigned long start_time;
    unsigned long total_time = 0;
    unsigned int avg_time = 0;
    unsigned int modified_score = 0;
    unsigned int wait_time;
    unsigned int trial_type;       // 0 = red, 1 = green
    unsigned int good_trials = 0;
    unsigned int failed_trials = 0;
    unsigned int restart = 0;

    WDTCTL = WDTPW | WDTHOLD;   // Stop watchdog timer

    // Clock setup: DCO = 1 MHz
    DCOCTL = 0;
    BCSCTL1 = CALBC1_1MHZ;
    DCOCTL = CALDCO_1MHZ;

    // LED setup: P1.4 = red, P1.6 = green
    P1DIR |= BIT4 | BIT6;
    P1OUT &= ~(BIT4 | BIT6);

    // Button setup: P1.3 input with pull-up
    P1DIR &= ~BIT3;
    P1REN |= BIT3;
    P1OUT |= BIT3;
    P1IE  |= BIT3;
    P1IES |= BIT3;     // interrupt on falling edge
    P1IFG &= ~BIT3;

    // LCD setup
    P2DIR |= RS | EN | D4 | D5 | D6 | D7;
    P2OUT &= ~(RS | EN | D4 | D5 | D6 | D7);

    // Timer_A setup: 1 ms interrupt
    TA0CCR0 = 999;
    TA0CCTL0 = CCIE;
    TA0CTL = TASSEL_2 | MC_1 | TACLR;

    lcd_init();

    __bis_SR_register(GIE);   // Enable global interrupts

    while (1)
    {
        // Reset totals each run
        total_time = 0;
        good_trials = 0;
        failed_trials = 0;
        restart = 0;

        // Start screen / instructions
        lcd_clear();
        lcd_set_cursor(0, 0);
        lcd_print("Reaction Test");
        lcd_set_cursor(1, 0);
        lcd_print("Press to start");

        // Wait for user to press button
        button_pressed = 0;
        while (!button_pressed);

        delay_ms(300);  // small pause

        // Run 10 trials
        for (trial = 1; trial <= NUM_TRIALS; trial++)
        {
            // Trial message
            lcd_clear();
            lcd_set_cursor(0, 0);
            lcd_print("Trial ");
            lcd_print_trial(trial);
            lcd_set_cursor(1, 0);
            lcd_print("Wait...");
            P1OUT &= ~(BIT4 | BIT6);

            // Clear old press flag
            button_pressed = 0;

            // Random delay before LED turns on
            // Detect early press during this wait
            wait_time = random_delay();
            start_time = time_ms;
            restart = 0;

            while ((time_ms - start_time) < wait_time)
            {
                if (button_pressed)
                {
                    lcd_clear();
                    lcd_set_cursor(0, 0);
                    lcd_print("Too Early!");
                    lcd_set_cursor(1, 0);
                    lcd_print("Start Again");

                    P1OUT &= ~(BIT4 | BIT6);
                    delay_ms(2000);

                    restart = 1;
                    break;
                }
            }

            // If early press happened, leave trial loop immediately
            if (restart)
            {
                break;
            }

            // Choose trial type
            trial_type = (wait_time / 100) % 2;   // 0 = red, 1 = green

            // Green Trial: User must press
            if (trial_type == 1)
            {
                lcd_clear();
                lcd_set_cursor(0, 0);
                lcd_print("Trial ");
                lcd_print_trial(trial);
                lcd_set_cursor(1, 0);
                lcd_print("Green");

                P1OUT |= BIT6;     // green LED ON
                P1OUT &= ~BIT4;    // red LED OFF

                start_time = time_ms;
                button_pressed = 0;   // only count presses after LED turns on

                while (!button_pressed);

                reaction_time = (unsigned int)(time_ms - start_time);
                total_time += reaction_time;
                good_trials++;

                P1OUT &= ~BIT6;    // green LED OFF

                lcd_clear();
                lcd_set_cursor(0, 0);
                lcd_print("Time:");
                lcd_set_cursor(1, 0);
                lcd_print_time(reaction_time);

                delay_ms(1500);
            }
            // Red trial: user should not press
            else
            {
                lcd_clear();
                lcd_set_cursor(0, 0);
                lcd_print("Trial ");
                lcd_print_trial(trial);
                lcd_set_cursor(1, 0);
                lcd_print("Red");

                P1OUT |= BIT4;     // red LED ON
                P1OUT &= ~BIT6;    // green LED OFF

                button_pressed = 0;
                start_time = time_ms;

                // Watch for 1.5 seconds to see if user presses
                while (((time_ms - start_time) < 1500) && !button_pressed);

                P1OUT &= ~BIT4;    // red LED OFF

                lcd_clear();
                if (button_pressed)
                {
                    failed_trials++;
                    lcd_set_cursor(0, 0);
                    lcd_print("Failed Trial");
                    lcd_set_cursor(1, 0);
                    lcd_print("Pressed on red");
                }
                else
                {
                    lcd_set_cursor(0, 0);
                    lcd_print("Correct");
                    lcd_set_cursor(1, 0);
                    lcd_print("No press");
                }

                delay_ms(1500);
            }
        }

        // If user pressed too early, restart immediately
        if (restart)
        {
            continue;
        }

        // Compute average using only successful green trials
        if (good_trials > 0)
            avg_time = (unsigned int)(total_time / good_trials);
        else
            avg_time = 0;

        // Modified score = average + penalty for failed red-light presses
        modified_score = avg_time + (failed_trials * 200);

        // Show average time
        lcd_clear();
        lcd_set_cursor(0, 0);
        lcd_print("Avg Green Time:");
        lcd_set_cursor(1, 0);
        lcd_print_time(avg_time);

        delay_ms(2500);

        // Show failed trials
        lcd_clear();
        lcd_set_cursor(0, 0);
        lcd_print("Failed Trials:");
        lcd_set_cursor(1, 0);
        lcd_print_num(failed_trials);

        delay_ms(2500);

        // Show modified score
        lcd_clear();
        lcd_set_cursor(0, 0);
        lcd_print("Modified Score");
        lcd_set_cursor(1, 0);
        lcd_print_time(modified_score);

        delay_ms(4000);
    }
}

// Timer_A ISR: 1 ms time base
#pragma vector=TIMER0_A0_VECTOR
__interrupt void Timer_A(void)
{
    time_ms++;
}

// Port 1 ISR: button press detection with debounce
#pragma vector=PORT1_VECTOR
__interrupt void Port_1(void)
{
    if (P1IFG & BIT3)
    {
        if ((time_ms - last_press) > 200)
        {
            last_press = time_ms;
            button_pressed = 1;
        }

        P1IFG &= ~BIT3;
    }
}

// Random delay: returns about 1000 to 3999 ms
unsigned int random_delay(void)
{
    return 1000 + (time_ms % 3000);
}

// LCD helper: enable pulse
void lcd_pulse_enable(void)
{
    P2OUT |= EN;
    __delay_cycles(1000);
    P2OUT &= ~EN;
    __delay_cycles(1000);
}

// LCD helper: send nibble
void lcd_send_nibble(unsigned char nibble)
{
    P2OUT &= ~(D4 | D5 | D6 | D7);

    if (nibble & 0x01) P2OUT |= D4;
    if (nibble & 0x02) P2OUT |= D5;
    if (nibble & 0x04) P2OUT |= D6;
    if (nibble & 0x08) P2OUT |= D7;

    lcd_pulse_enable();
}

// Send LCD command
void lcd_cmd(unsigned char cmd)
{
    P2OUT &= ~RS;
    lcd_send_nibble(cmd >> 4);
    lcd_send_nibble(cmd & 0x0F);
    delay_ms(2);
}

// Send LCD data
void lcd_data(unsigned char data)
{
    P2OUT |= RS;
    lcd_send_nibble(data >> 4);
    lcd_send_nibble(data & 0x0F);
    delay_ms(2);
}

// LCD init in 4-bit mode
void lcd_init(void)
{
    delay_ms(50);

    P2OUT &= ~RS;

    lcd_send_nibble(0x03);
    delay_ms(5);
    lcd_send_nibble(0x03);
    delay_ms(5);
    lcd_send_nibble(0x03);
    delay_ms(5);
    lcd_send_nibble(0x02);

    lcd_cmd(0x28);   // 4-bit mode, 2 lines
    lcd_cmd(0x0C);   // display on, cursor off
    lcd_cmd(0x06);   // entry mode
    lcd_cmd(0x01);   // clear
    delay_ms(2);
}

// Clear LCD
void lcd_clear(void)
{
    lcd_cmd(0x01);
    delay_ms(2);
}

// Set cursor
void lcd_set_cursor(unsigned char row, unsigned char col)
{
    if (row == 0)
        lcd_cmd(0x80 + col);
    else
        lcd_cmd(0xC0 + col);
}

// Print string
void lcd_print(char *str)
{
    while (*str)
    {
        lcd_data(*str);
        str++;
    }
}

// Print trial number correctly, including 10
void lcd_print_trial(unsigned int trial)
{
    if (trial == 10)
    {
        lcd_data('1');
        lcd_data('0');
    }
    else
    {
        lcd_data(trial + '0');
    }
}

// Print general number (0-9999)
void lcd_print_num(unsigned int num)
{
    unsigned int thousands, hundreds, tens, ones;

    thousands = (num / 1000) % 10;
    hundreds  = (num / 100) % 10;
    tens      = (num / 10) % 10;
    ones      = num % 10;

    if (num >= 1000)
        lcd_data(thousands + '0');
    if (num >= 100)
        lcd_data(hundreds + '0');
    if (num >= 10)
        lcd_data(tens + '0');

    lcd_data(ones + '0');
}

// Print time in ms
void lcd_print_time(unsigned int ms)
{
    unsigned int thousands, hundreds, tens, ones;

    thousands = (ms / 1000) % 10;
    hundreds  = (ms / 100) % 10;
    tens      = (ms / 10) % 10;
    ones      = ms % 10;

    if (ms >= 1000)
        lcd_data(thousands + '0');

    lcd_data(hundreds + '0');
    lcd_data(tens + '0');
    lcd_data(ones + '0');
    lcd_data(' ');
    lcd_data('m');
    lcd_data('s');
}

// Approximate ms delay for 1 MHz clock
void delay_ms(unsigned int ms)
{
    while (ms--)
    {
        __delay_cycles(1000);
    }
}
